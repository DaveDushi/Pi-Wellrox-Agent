{
  "name": "pi-wellrox-agent",
  "version": "0.1.5",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "build:ts": "tsc",
    "dev": "tsc && electron .",
    "start": "electron .",
    "prepare-ffmpeg": "node scripts/prepare-ffmpeg.cjs",
    "prepare-git": "node scripts/prepare-git.cjs",
    "build": "tsc && npm run prepare-ffmpeg && npm run prepare-git && electron-builder",
    "server": "node dist/main.js"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@mariozechner/pi-coding-agent": "latest",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "hono": "^4"
  },
  "devDependencies": {
    "@types/node": "^22",
    "electron": "^33",
    "electron-builder": "^25",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.wellrox.pi-agent",
    "productName": "Pi Wellrox Agent",
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "skills",
        "to": "skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/ffmpeg",
        "to": "ffmpeg",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/git",
        "to": "git",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "DaveDushi",
        "repo": "Pi-Wellrox-Agent"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Pi-Wellrox-Agent-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
